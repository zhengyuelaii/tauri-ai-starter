{
  "name": "tauri-ai-starter",
  "version": "1.0.0",
  "description": "Desktop AI Chat app template built with Tauri v2 + Vue 3 + NestJS. Multi-model support, cross-platform, clean and extensible codebase.",
  "private": true,
  "main": "index.js",
  "scripts": {
    "tauri": "pnpm --filter @tauri-ai-starter/desktop tauri",
    "tauri:dev": "pnpm --filter @tauri-ai-starter/desktop tauri dev",
    "dev": "pnpm --filter @tauri-ai-starter/shared build && node packages/desktop/scripts/dev.cjs",
    "web:dev": "pnpm --filter @tauri-ai-starter/desktop dev",
    "server:dev": "pnpm --filter @tauri-ai-starter/server start:dev",
    "server:build": "pnpm --filter @tauri-ai-starter/server build",
    "server:test": "pnpm --filter @tauri-ai-starter/server test",
    "desktop:test": "pnpm --filter @tauri-ai-starter/desktop test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.4.0",
      "onFail": "download"
    }
  },
  "type": "module"
}
