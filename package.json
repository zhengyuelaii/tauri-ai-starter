{
  "name": "tauri-monorepo-app",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "main": "index.js",
  "scripts": {
    "tauri": "pnpm --filter @tauri-monorepo/desktop tauri",
    "tauri:dev": "pnpm --filter @tauri-monorepo/desktop tauri dev",
    "dev": "pnpm --filter @tauri-monorepo/shared build && node packages/desktop/scripts/dev.cjs",
    "web:dev": "pnpm --filter @tauri-monorepo/desktop dev",
    "server:dev": "pnpm --filter @tauri-monorepo/server start:dev",
    "server:build": "pnpm --filter @tauri-monorepo/server build",
    "server:test": "pnpm --filter @tauri-monorepo/server test",
    "desktop:test": "pnpm --filter @tauri-monorepo/desktop test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.4.0",
      "onFail": "download"
    }
  },
  "type": "module"
}
